# ── 服务配置 ──────────────────────────────────────
PORT=7861
WORKERS=1
ADMIN_KEY=admin
REGISTER_SECRET=

# ── 引擎模式（doubao 仅支持 browser）───────────────
ENGINE_MODE=browser

# ── 浏览器引擎配置 ────────────────────────────────
BROWSER_POOL_SIZE=2
MAX_INFLIGHT=1
STREAM_KEEPALIVE_INTERVAL=5

# ── 容灾与限流 ───────────────────────────────────
ACCOUNT_MIN_INTERVAL_MS=1200
REQUEST_JITTER_MIN_MS=120
REQUEST_JITTER_MAX_MS=360
RATE_LIMIT_BASE_COOLDOWN=600
RATE_LIMIT_MAX_COOLDOWN=3600

# ── 豆包特有配置 ──────────────────────────────────
BASE_URL=https://www.doubao.com
DEFAULT_BOT_ID=7338286299411103781
DEFAULT_FP=doubao2api_default_fp
